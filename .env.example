# ── Chain ─────────────────────────────────────────────────────────────────
# Local forge-fhevm Anvil node (chain id 31337)
RPC_URL=http://localhost:8545
CHAIN_ID=31337

# ERC-7984 confidential token contract (set by scripts/deploy-token.ts)
TOKEN_ADDRESS=

# fhEVM ACL system contract (canonical address from forge-fhevm deploy-local.sh)
ACL_CONTRACT_ADDRESS=

# ── Zama SDK ──────────────────────────────────────────────────────────────
# Optional: relayer API key for production; for local forge-fhevm cleartext mode, leave blank.
RELAYER_API_KEY=

# Indexer's signing EOA. Used by LocalEoaSigner to userDecrypt confidential balances.
INDEXER_PRIVATE_KEY=

# ── Postgres ──────────────────────────────────────────────────────────────
# TODO(slop): credentials embedded in a URL (`protocol://user:pass@host`) — leak via logs / shell history / crash reports; move to env vars or a connection-options struct
DATABASE_URL=postgres://postgres:postgres@localhost:5432/envio_db
APP_SCHEMA=app

# ── NATS ──────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_REPLICAS=1
NATS_MAX_DELIVER=3
NATS_ACK_WAIT_SECONDS=30

# ── API ───────────────────────────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
INDEXER_BEHIND_THRESHOLD_BLOCKS=20

# ── Sepolia (DOCUMENTATION ONLY, not run by this submission) ──────────────
# SEPOLIA_RPC_URL=
# SEPOLIA_TOKEN_ADDRESS=
# SEPOLIA_RELAYER_URL=
