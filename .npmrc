# Supply-chain hygiene — refuse package versions younger than 7 days.
# Mitigates compromised-publish attacks: malicious versions are usually
# detected by ecosystem monitoring + taken down within a few days, so a
# 7-day grace window dramatically reduces blast radius without burdening
# routine upgrades.
# Value is in minutes (pnpm v10+). 7 days = 7×24×60 = 10080.
minimum-release-age=10080

# Pin Node loader strictness.
strict-peer-dependencies=false
auto-install-peers=true
